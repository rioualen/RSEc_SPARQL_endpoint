@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix ex:     <https://example.org/software/> .
@prefix biotools: <https://bio.tools/ontology/> .

ex:biopython
    rdf:type         schema:SoftwareApplication ;
    rdfs:label       "Biopython" ;
    rdfs:comment     "A set of freely available tools for biological computation in Python." ;
    schema:version   "1.83" ;
    schema:license   "https://spdx.org/licenses/Biopython.html" ;
    schema:url       <https://biopython.org> ;
    biotools:topic   ex:topic_sequence_analysis .

ex:snakemake
    rdf:type         schema:SoftwareApplication ;
    rdfs:label       "Snakemake" ;
    rdfs:comment     "A workflow management system for reproducible data analysis." ;
    schema:version   "8.5.3" ;
    schema:license   "https://spdx.org/licenses/MIT.html" ;
    schema:url       <https://snakemake.github.io> ;
    biotools:topic   ex:topic_workflows .

ex:topic_sequence_analysis
    rdf:type   biotools:Topic ;
    rdfs:label "Sequence analysis" .

ex:topic_workflows
    rdf:type   biotools:Topic ;
    rdfs:label "Workflows" .
